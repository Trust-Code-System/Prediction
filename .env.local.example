# Copy to .env.local and fill in. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API-Football (api-sports.io)
API_FOOTBALL_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini (used as an alternative upcoming-fixtures source)
GEMINI_API_KEY=

# Tavily (web search; feeds recent match news into the prediction)
TAVILY_API_KEY=

# OpenAI (fallback predictor; used only if Claude fails validation)
OPENAI_API_KEY=
# Optional override, default gpt-4o
# OPENAI_PREDICTION_MODEL=gpt-4o

# Shared secret protecting the cron + manual refresh routes
CRON_SECRET=

# Optional: minimum ms between API-Football requests. Default 6500 keeps under
# the free plan's 10 requests/minute limit. Paid plans can lower this (e.g. 250)
# for much faster ingest.
# API_FOOTBALL_MIN_SPACING_MS=6500
